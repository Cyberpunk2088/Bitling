config_version=5

[application]
config/name="BITLING OMNI"
config/description="An original partner-world game with expressive 3D companionship, recoverable care, autonomous learning, settlement growth, legacy and explainable evolution."
config/version="0.5.0"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.6", "Mobile")

[autoload]
EventBus="*res://scripts/core/event_bus.gd"
StreakService="*res://scripts/core/streak_service.gd"
QuestService="*res://scripts/core/quest_service.gd"
PlatformService="*res://scripts/core/platform_service.gd"
ProductionQuality="*res://scripts/core/production_quality_service.gd"
CompanionBrain="*res://scripts/core/companion_brain.gd"
BitlingIdentity="*res://scripts/social/bitling_identity.gd"
DevelopmentProfile="*res://scripts/core/development_profile.gd"
EmotionModel="*res://scripts/social/emotion_model.gd"
BitlingLanguage="*res://scripts/social/bitling_language.gd"
LanguageBridge="*res://scripts/social/language_bridge.gd"
MediaCapabilityService="*res://scripts/social/media_capability_service.gd"
SocialSessionService="*res://scripts/social/social_session_service.gd"
LineageService="*res://scripts/social/lineage_service.gd"
WellbeingGuard="*res://scripts/core/wellbeing_guard.gd"
AdaptiveLearning="*res://scripts/core/adaptive_learning.gd"
EvolutionService="*res://scripts/core/evolution_service.gd"
VitalityService="*res://scripts/core/vitality_service.gd"
ExplorationService="*res://scripts/core/exploration_service.gd"
PartnerWorld="*res://scripts/core/partner_world_runtime.gd"
EvolutionMatrix="*res://scripts/core/evolution_matrix_runtime.gd"
DialogueDirector="*res://scripts/core/dialogue_director.gd"
OmniAudio="*res://scripts/audio/omni_audio_director.gd"
GameState="*res://scripts/core/game_state.gd"
PartnerWorldStore="*res://scripts/core/partner_world_store.gd"
HapticService="*res://scripts/platform/haptic_service.gd"
DialogueToast="*res://scripts/ui/dialogue_toast.gd"
LearningOverlay="*res://scripts/ui/learning_overlay.gd"
ExplorationOverlay="*res://scripts/ui/exploration_overlay.gd"
EvolutionOverlay="*res://scripts/ui/evolution_overlay.gd"
ProfileOverlay="*res://scripts/ui/profile_overlay.gd"
PartnerWorldOverlay="*res://scripts/ui/partner_world_overlay_runtime.gd"

[audio]
driver/enable_input=true

[display]
window/size/viewport_width=720
window/size/viewport_height=1280
window/size/window_width_override=720
window/size/window_height_override=1280
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1
window/vsync/vsync_mode=1
window/energy_saving/keep_screen_on=false
window/dpi/allow_hidpi=true

[rendering]
renderer/rendering_method="mobile"
renderer/rendering_method.mobile="mobile"
textures/default_filters/use_nearest_mipmap_filter=false
environment/defaults/default_clear_color=Color(0.015, 0.02, 0.03, 1)

[debug]
gdscript/warnings/unassigned_variable=1
gdscript/warnings/unsafe_method_access=1
gdscript/warnings/unsafe_property_access=1
